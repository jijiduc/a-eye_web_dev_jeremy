[Unit]
Description=Renew Let's Encrypt certificates for A-eye
Requires=docker.service aeyeweb.service
After=docker.service aeyeweb.service

[Service]
Type=oneshot
WorkingDirectory=/home/debi/jaime/repos/a-eye/a-eye_web
ExecStart=/usr/bin/docker compose run --rm certbot renew --webroot -w /var/www/certbot
ExecStartPost=/usr/bin/docker compose exec -T nginx nginx -s reload
